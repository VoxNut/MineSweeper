<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
  <display-name>minesweeper</display-name>

  <listener>
    <listener-class>com.minesweeper.util.FirebaseUtil</listener-class>
  </listener>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.minesweeper.filter.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>AdminFilter</filter-name>
    <filter-class>com.minesweeper.filter.AdminFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AdminFilter</filter-name>
    <url-pattern>/admin/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>HomeServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.HomeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>HowToPlayServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.HowToPlayServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HowToPlayServlet</servlet-name>
    <url-pattern>/howtoplay</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.auth.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/auth/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminLoginServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.auth.AdminLoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminLoginServlet</servlet-name>
    <url-pattern>/admin/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.auth.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/auth/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GameServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.game.GameServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GameServlet</servlet-name>
    <url-pattern>/game</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GameApiServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.game.GameApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GameApiServlet</servlet-name>
    <url-pattern>/api/game</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LeaderboardServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.score.LeaderboardServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LeaderboardServlet</servlet-name>
    <url-pattern>/leaderboard</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>HistoryServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.score.HistoryServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HistoryServlet</servlet-name>
    <url-pattern>/history</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminUserServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.admin.AdminUserServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminUserServlet</servlet-name>
    <url-pattern>/admin/users</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.admin.AdminDashboardServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <url-pattern>/admin</url-pattern>
    <url-pattern>/admin/dashboard</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminScoreServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.admin.AdminScoreServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminScoreServlet</servlet-name>
    <url-pattern>/admin/scores</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminConfigServlet</servlet-name>
    <servlet-class>com.minesweeper.servlet.admin.AdminConfigServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminConfigServlet</servlet-name>
    <url-pattern>/admin/config</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>home</welcome-file>
  </welcome-file-list>
</web-app>

<!-- Security constraint routes filters updated -->
